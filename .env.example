# Google Analytics Measurement ID
# Get this from your Google Analytics 4 property
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# In lower envs (dev/staging): set to 'true' to show "Become a Member" / create-client. In production, create-client is always enabled.
# VITE_SHOW_CREATE_CLIENT=true
